{
  "name": "grogvm",
  "version": "0.0.0",
  "description": "A from-scratch TypeScript reimplementation of SCUMM v5 (Monkey Island 1 & 2) for the browser.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:verbose": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:integration:beat-saves": "BEAT_SAVES=1 vitest run --config vitest.integration.config.ts integration/mi1/walkthrough.test.ts",
    "disgrogate": "npx tsx tools/disgrogate.ts",
    "mugshot": "npx tsx tools/mugshot.ts"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/wicg-file-system-access": "^2023.10.7",
    "fake-indexeddb": "^6.2.5",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.9.0",
    "markdown-it": "^14.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
